# Copy this file to .env and fill in your values.
# .env is gitignored and must never be committed.

# ── Telegram ──────────────────────────────────────────────────────────────────
# Get your token from @BotFather on Telegram
TELEGRAM_BOT_TOKEN=your_bot_token_here

# ── Email bridge ──────────────────────────────────────────────────────────────
# The bot's own email account (used to send to the secretariat and receive replies)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
IMAP_HOST=imap.gmail.com
IMAP_PORT=993
EMAIL_USERNAME=bot@your-domain.com
EMAIL_PASSWORD=your_email_password_or_app_password

# The secretariat's email address — all client requests are forwarded here
SECRETARIAT_EMAIL=secretary@example.com

# How often (seconds) the bot polls the inbox for secretary replies (default: 30)
EMAIL_POLL_INTERVAL=30

# ── AI model selection ────────────────────────────────────────────────────────
# Available: claude-opus-4-7, claude-sonnet-4-6, claude-haiku-4-5,
#            gpt-4o, gpt-4o-mini, gemini-2.0-flash, gemini-1.5-pro
ACTIVE_MODEL=claude-sonnet-4-6
ANTHROPIC_API_KEY=sk-ant-...
OPENAI_API_KEY=sk-...
GEMINI_API_KEY=AIza...

# ── Monthly reminder pipeline (pipeline.py) ───────────────────────────────────
# Override the reporting month (defaults to current month)
# CURRENT_MONTH=2026-05

# Set to false to send real WhatsApp messages via Twilio
USE_MOCK=true
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=your_auth_token_here
TWILIO_WHATSAPP_FROM=whatsapp:+14155238886

# ── Logging ───────────────────────────────────────────────────────────────────
LOG_LEVEL=INFO
