TELEGRAM_BOT_TOKEN=your_bot_token_here

# ── Email provider ────────────────────────────────────────────────────────────
# IMPORTANT: activate exactly ONE provider block at a time.
# Comment out the block you are not using.
#
# Both Gmail and Yahoo require an App Password (not your regular login password).
#   Gmail:  https://myaccount.google.com → Security → App passwords
#   Yahoo:  https://login.yahoo.com → Security → Generate app password
# ─────────────────────────────────────────────────────────────────────────────

# ── OPTION 1: Gmail (active by default — comment out if using Yahoo) ──────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
IMAP_HOST=imap.gmail.com
IMAP_PORT=993

# ── OPTION 2: Yahoo (uncomment this block and comment out Option 1 to use) ───
# SMTP_HOST=smtp.mail.yahoo.com
# SMTP_PORT=587
# IMAP_HOST=imap.mail.yahoo.com
# IMAP_PORT=993

# ── Credentials (fill in for whichever provider is active above) ──────────────
EMAIL_USERNAME=your_email@provider.com
EMAIL_PASSWORD=your_app_password_here
SECRETARIAT_EMAIL=secretariat@your-domain.com

# ── Polling & logging ─────────────────────────────────────────────────────────
EMAIL_POLL_INTERVAL=30
LOG_LEVEL=INFO
