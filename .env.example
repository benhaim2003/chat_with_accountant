TELEGRAM_BOT_TOKEN=your_bot_token_here

# ── Microsoft Graph API (Outlook / Microsoft 365) ────────────────────────────
AZURE_TENANT_ID=your-tenant-id-here
AZURE_CLIENT_ID=your-client-id-here
AZURE_CLIENT_SECRET=your-client-secret-here

EMAIL_USERNAME=bot@mail.co.il
SECRETARIAT_EMAIL=secretary@mail.co.il

# ── Redis ─────────────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0

# ── WhatsApp Cloud API (Meta) ─────────────────────────────────────────────────
WHATSAPP_TOKEN=your-whatsapp-access-token-here
WHATSAPP_PHONE_NUMBER_ID=your-phone-number-id-here
WHATSAPP_BUSINESS_ACCOUNT_ID=your-business-account-id-here
WHATSAPP_VERIFY_TOKEN=your-webhook-verify-token-here

# ── Polling & logging ─────────────────────────────────────────────────────────
EMAIL_POLL_INTERVAL=30
LOG_LEVEL=INFO
