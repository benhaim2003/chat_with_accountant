TELEGRAM_BOT_TOKEN=your_bot_token_here

# ── Microsoft Graph API (Outlook / Microsoft 365) ────────────────────────────
# Required to send and receive emails via the Graph API.
# Set these up by registering an app in Azure AD (Entra):
#   1. Go to portal.azure.com → Azure Active Directory → App registrations → New registration
#   2. Add a client secret under Certificates & secrets
#   3. Add API permissions: Mail.Read, Mail.Send, Mail.ReadWrite (Application type, not Delegated)
#   4. Grant admin consent for the permissions
AZURE_TENANT_ID=your-tenant-id-here
AZURE_CLIENT_ID=your-client-id-here
AZURE_CLIENT_SECRET=your-client-secret-here

# The mailbox the bot acts as (sends from and reads replies in)
EMAIL_USERNAME=bot@mail.co.il
# Where client request emails are sent (the secretary)
SECRETARIAT_EMAIL=secretary@mail.co.il

# ── Polling & logging ─────────────────────────────────────────────────────────
EMAIL_POLL_INTERVAL=30
LOG_LEVEL=INFO
