# Copy this file to .env and fill in your values.
# .env is gitignored and must never be committed.

# Override the reporting month (defaults to current month if not set)
# CURRENT_MONTH=2026-05

# Set to false to send real WhatsApp messages via Twilio
USE_MOCK=true

# Twilio credentials — required only when USE_MOCK=false
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=your_auth_token_here
TWILIO_WHATSAPP_FROM=whatsapp:+14155238886

# Log level: DEBUG, INFO, WARNING, ERROR
LOG_LEVEL=INFO

# --- AI model selection ---
# Set ACTIVE_MODEL to any key from model_config.py to switch providers/models.
# Available keys: claude-opus-4-7, claude-sonnet-4-6, claude-haiku-4-5,
#                 gpt-4o, gpt-4o-mini, gemini-2.0-flash, gemini-1.5-pro
# Defaults to claude-sonnet-4-6 if not set.
ACTIVE_MODEL=claude-sonnet-4-6

# Provider API keys — only the key for your chosen provider is required.
ANTHROPIC_API_KEY=sk-ant-...
OPENAI_API_KEY=sk-...
GEMINI_API_KEY=AIza...
