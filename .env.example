TELEGRAM_BOT_TOKEN=your_bot_token_here

# ── Email provider ────────────────────────────────────────────────────────────
# Copy ONE of the blocks below and fill in your credentials.
# Both Gmail and Yahoo require an App Password (not your regular login password).
#   Gmail:  https://myaccount.google.com → Security → App passwords
#   Yahoo:  https://login.yahoo.com → Security → Generate app password

# Gmail (STARTTLS on 587)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
IMAP_HOST=imap.gmail.com
IMAP_PORT=993

# Yahoo — option A: STARTTLS on 587 (same flow as Gmail)
# SMTP_HOST=smtp.mail.yahoo.com
# SMTP_PORT=587
# IMAP_HOST=imap.mail.yahoo.com
# IMAP_PORT=993

# Yahoo — option B: implicit SSL on 465 (also supported)
# SMTP_HOST=smtp.mail.yahoo.com
# SMTP_PORT=465
# IMAP_HOST=imap.mail.yahoo.com
# IMAP_PORT=993

EMAIL_USERNAME=bot@your-domain.com
EMAIL_PASSWORD=your_app_password_here
SECRETARIAT_EMAIL=secretariat@your-domain.com

# ── Polling & logging ─────────────────────────────────────────────────────────
EMAIL_POLL_INTERVAL=30
LOG_LEVEL=INFO
